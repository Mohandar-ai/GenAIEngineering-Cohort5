# Optional: enables the LLM path in the "question" node (via OpenRouter).
# The default graph runs WITHOUT any key — leave this blank for the live demo.
# To try the LLM branch, copy this file to .env and fill in your key:
#   cp .env.example .env
OPENROUTER_API_KEY=
# Optional: override the model used for the OpenRouter LLM path.
OPENROUTER_MODEL=openai/gpt-4o-mini
